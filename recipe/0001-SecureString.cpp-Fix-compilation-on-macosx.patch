From 2f63ba2decb5658237d798e69abb04d36685e699 Mon Sep 17 00:00:00 2001
From: Thomas Braun <thomas.braun@byte-physics.de>
Date: Sun, 21 Sep 2025 15:52:45 +0200
Subject: [PATCH 1/2] SecureString.cpp: Reorder header includes

This ensures that we don't include anything else before handling the ifdef magic for
our clear memory functions.
---
 SecureString.cpp | 9 ++++-----
 1 file changed, 4 insertions(+), 5 deletions(-)

diff --git a/SecureString.cpp b/SecureString.cpp
index ac548a5..d23d421 100644
--- a/SecureString.cpp
+++ b/SecureString.cpp
@@ -1,15 +1,14 @@
-#include "SecureString.h"
-
 #include <cmake_config.h>
 
-#include <algorithm>
-
-#include <string.h>
 
 #if defined(TANGO_SECURE_ZERO_MEMORY)
   #include <windows.h>
 #endif
 
+#include "SecureString.h"
+
+#include <algorithm>
+
 namespace
 {
 void safe_clear(void *ptr, size_t len)
-- 
