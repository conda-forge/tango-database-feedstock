From 74b75c3a41a498e0a1b4400965af339086693f29 Mon Sep 17 00:00:00 2001
From: Thomas Braun <thomas.braun@byte-physics.de>
Date: Sun, 21 Sep 2025 15:56:07 +0200
Subject: [PATCH 2/2] SecureString.cpp: Fix compilation on macosx

We need to define __STDC_WANT_LIB_EXT1__ to 1 before including the string header.
In addition the call did not match the signature.
---
 SecureString.cpp | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/SecureString.cpp b/SecureString.cpp
index d23d421..536a328 100644
--- a/SecureString.cpp
+++ b/SecureString.cpp
@@ -1,5 +1,10 @@
 #include <cmake_config.h>
 
+#if defined(TANGO_MEMSET_S)
+  #define __STDC_WANT_LIB_EXT1__ 1
+#endif
+
+#include <cstring>
 
 #if defined(TANGO_SECURE_ZERO_MEMORY)
   #include <windows.h>
@@ -18,7 +23,7 @@ void safe_clear(void *ptr, size_t len)
 #elif defined(TANGO_SECURE_ZERO_MEMORY)
     SecureZeroMemory(ptr, len);
 #elif defined(TANGO_MEMSET_S)
-    memset_s(ptr, len);
+    memset_s(ptr, len, 0, len);
 #elif defined(TANGO_BZERO)
     bzero(ptr, len);
 #else
-- 
